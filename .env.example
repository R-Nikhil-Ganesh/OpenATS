# ==============================================================
# OPENATS — AI Recruiting Platform
# Environment Variables Example
# Copy this file to .env and fill in real values before running.
# ==============================================================

# ---------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=openats
POSTGRES_USER=openats
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://openats:changeme@localhost:5432/openats

# ---------------------------------------------------------------
# Redis
# ---------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------
JWT_ACCESS_SECRET=change_me_access_secret_32chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------------------------------------------------------------
# API Server
# ---------------------------------------------------------------
API_PORT=3001
API_BASE_URL=http://localhost:3001
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ---------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------
VITE_PUBLIC_API_URL=http://localhost:3001
# Legacy alias still read as a fallback by the frontend; prefer
# VITE_PUBLIC_API_URL above for new setups.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Used by the API to set the CORS allow-origin (see apps/api/src/config.ts).
FRONTEND_URL=http://localhost:3000

# ---------------------------------------------------------------
# vLLM Inference Engine
# ---------------------------------------------------------------
VLLM_BASE_URL=http://host.docker.internal:11434
VLLM_MODEL=llama3.2:3b
# Candidate comparison is low-volume/interactive, so it can afford a
# stronger model than the high-throughput scoring path above.
VLLM_COMPARE_MODEL=qwen2.5-coder:7b
# MD->JSON profile extraction is a mechanical transformation, so it runs
# on a smaller model than scoring/compare.
VLLM_PROFILE_MODEL=qwen2.5-coder:1.5b
VLLM_MAX_TOKENS=800
VLLM_TEMPERATURE=0.1
# Small models answer in single-digit seconds even under load; this still
# leaves real margin. Raise this if you switch to a larger/slower model.
VLLM_TIMEOUT_SECONDS=60
# llama3.2:3b (and similarly small models) handle several concurrent scoring
# calls well. Drop this to 1 if you switch to a larger model that serializes
# requests instead of batching them.
VLLM_MAX_CONCURRENT_REQUESTS=4

# ---------------------------------------------------------------
# Embeddings
# ---------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ---------------------------------------------------------------
# Worker (BullMQ)
# ---------------------------------------------------------------
BULLMQ_QUEUE_NAME=resume-processing
WORKER_CONCURRENCY=4

# ---------------------------------------------------------------
# NVIDIA NIM API (DeepSeek/R1) — OPTIONAL cloud fallback, OFF by default.
# Interactive LLM calls (candidate compare / ask) run on local Ollama unless
# you explicitly opt in by setting BOTH LLM_USE_NVIDIA=true and a key below.
# ---------------------------------------------------------------
# LLM_USE_NVIDIA=false
# NVIDIA_API_KEY=
# NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=deepseek-ai/deepseek-r1
